.sn{font-size:21px;font-weight:600}
.tw{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:12px;min-width:700px}
th{font-weight:600;text-align:left;padding:7px 8px;border-bottom:.5px solid var(--border2);color:var(--text2);font-size:11px;white-space:nowrap;background:var(--bg2)}
td{padding:7px 8px;border-bottom:.5px solid var(--border);vertical-align:top}
tr:hover td{background:var(--bg2)}
tr:last-child td{border-bottom:none}
.ch{font-size:10px;padding:2px 7px;border-radius:10px;font-weight:600;white-space:nowrap}
.cok{background:var(--ok-bg);color:var(--ok-text)}
.cwn{background:var(--warn-bg);color:var(--warn-text)}
.cng{background:var(--err-bg);color:var(--err-text)}
.mt{text-align:center;padding:2rem;color:var(--text3);font-size:13px}
.nt{font-size:11px;color:var(--text3);margin-top:10px;line-height:1.5}
.sep{height:.5px;background:var(--border);margin:1rem 0}
.cfgbox{background:var(--warn-bg);color:var(--warn-text);border-radius:var(--rl);padding:1.25rem;font-size:13px;line-height:1.8;margin-bottom:1rem}
