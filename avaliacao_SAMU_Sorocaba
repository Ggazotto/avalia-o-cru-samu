/* ════ API JSONBIN ════ */
const API='https://api.jsonbin.io/v3/b';
const cfgOk=()=>BIN_ID!=='COLE_O_BIN_ID_AQUI'&&API_KEY!=='COLE_A_API_KEY_AQUI';

async function dbLoad(){
  if(!cfgOk())return[];
  try{const r=await fetch(`${API}/${BIN_ID}/latest`,{headers:{'X-Master-Key':API_KEY}});const j=await r.json();return Array.isArray(j.record)?j.record:[];}
  catch(e){return[];}
}
async function dbSave(rec){
  const all=await dbLoad();all.push(rec);
  await fetch(`${API}/${BIN_ID}`,{method:'PUT',headers:{'Content-Type':'application/json','X-Master-Key':API_KEY},body:JSON.stringify(all)});
}
async function dbDup(fn,mat){const a=await dbLoad();return a.some(r=>r.fn===fn&&r.profile.mat===mat);}
async function dbClear(){await fetch(`${API}/${BIN_ID}`,{method:'PUT',headers:{'Content-Type':'application/json','X-Master-Key':API_KEY},body:'[]'});}

/* ════ HELPERS ════ */
function tQ(fn){let n=0;DATA[fn].sections.forEach(s=>{n+=s.questions.length});return n;}
function score(fn,ans){
  let ok=0,tot=0,c=0,cok=0,cf=[];
  DATA[fn].sections.forEach(s=>{s.questions.forEach(q=>{
    tot++;if(q.w==='c')c++;
    if(ans[q.id]===q.correct){ok++;if(q.w==='c')cok++;}
    else if(q.w==='c')cf.push(q.id);
  })});
  return{ok,tot,c,cok,cf};
}
function sig(p,cf){
  if(p>=80&&cf===0)return{l:'baseline adequado',c:'cok'};
  if(p>=60)return{l:'lacunas identificadas',c:'cwn'};
  return{l:'risco operacional',c:'cng'};
}
function fdt(ts){const d=new Date(ts);return d.toLocaleDateString('pt-BR')+' '+d.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'});}

/* ════ ESTADO ════ */
let S={sc:'login',fn:null,pf:{},ans:{},at:'tarm'};

/* ════ RENDER ════ */
function R(){
  const root=document.getElementById('root');
  if(S.sc==='login')root.innerHTML=rLogin();
  else if(S.sc==='blocked')root.innerHTML=rBlocked();
  else if(S.sc==='quiz')root.innerHTML=rQuiz();
  else if(S.sc==='done')root.innerHTML=rDone();
  else if(S.sc==='loading')root.innerHTML=`<div class="lb">Salvando respostas... Aguarde.</div>`;
  else if(S.sc==='admin')rAdminA();
}

function cfgWarn(){
  if(cfgOk())return'';
  return`<div class="cfgbox"><strong>Configuração pendente.</strong><br>Preencha <code>BIN_ID</code> e <code>API_KEY</code> no início do arquivo HTML conforme o Guia de Implantação.</div>`;
}

function rLogin(){return`
${cfgWarn()}
<p class="logo">SAMU 192 Sorocaba · Central de Regulação de Urgências</p>
<div class="card">
  <h2>Avaliação diagnóstica pré-treinamento</h2>
  <p class="sub">Preencha todos os campos obrigatórios (*) e insira o código de acesso fornecido pela coordenação. Cada matrícula permite uma única resposta.</p>
  <div class="fg">
    <div class="fw"><span class="fl">Nome completo *</span><input type="text" id="fn" placeholder="Nome completo"></div>
    <div class="fw"><span class="fl">Matrícula funcional *</span><input type="text" id="fm" placeholder="Ex.: 123456"></div>
  </div>
  <div class="fg">
    <div class="fw"><span class="fl">Cargo / função *</span>
      <select id="fc"><option value="">Selecione</option><option>TARM</option><option>Rádio Operador</option><option>Médico Regulador</option><option>Médico Intervencionista</option><option>Enfermeiro</option><option>Técnico de Enfermagem</option><option>Condutor de Ambulância</option><option>Outro</option></select>
    </div>
    <div class="fw"><span class="fl">Turno habitual *</span>
      <select id="ft"><option value="">Selecione</option><option>Diurno</option><option>Noturno</option><option>12x36 — dia</option><option>12x36 — noite</option><option>Escala variável</option></select>
    </div>
  </div>
  <div class="fg">
    <div class="fw"><span class="fl">Base / local de trabalho</span>
      <select id="fb"><option value="">Selecione</option><option>Central — Sorocaba</option><option>Base UPH Zona Norte</option><option>Base Votorantim</option><option>Base Araçariguama</option><option>Base Ibiúna</option><option>Base Iperó</option><option>Base Mairinque</option><option>Base Piedade</option><option>Base Pilar do Sul</option></select>
    </div>
    <div class="fw"><span class="fl">Tempo no serviço</span>
      <select id="fte"><option value="">Selecione</option><option>Menos de 1 ano</option><option>1 a 3 anos</option><option>3 a 5 anos</option><option>5 a 10 anos</option><option>Mais de 10 anos</option></select>
    </div>
  </div>
  <div class="fg full">
    <div class="fw"><span class="fl">Código de acesso *</span><input type="password" id="fk" placeholder="Código fornecido pela coordenação" onkeydown="if(event.key==='Enter')login()"></div>
  </div>
  <div class="ab ae" id="le">Verifique os campos obrigatórios e o código de acesso.</div>
  <div style="margin-top:12px"><button class="btn bp" id="blg" onclick="login()">Acessar avaliação</button></div>
  <p class="nt" style="margin-top:1rem">Uso exclusivo dos servidores da CRU — SAMU 192 Sorocaba. Cada matrícula permite uma única submissão.</p>
</div>`;}

async function login(){
  const nome=document.getElementById('fn').value.trim();
  const mat=document.getElementById('fm').value.trim();
  const cargo=document.getElementById('fc').value;
  const turno=document.getElementById('ft').value;
  const base=document.getElementById('fb').value||'Não informada';
  const tempo=document.getElementById('fte').value||'Não informado';
  const code=document.getElementById('fk').value.trim().toUpperCase();
  const role=CODES[code];
  document.getElementById('le').classList.remove('on');
  if(!nome||!mat||!cargo||!turno||!role){document.getElementById('le').classList.add('on');return;}
  const btn=document.getElementById('blg');btn.disabled=true;btn.textContent='Verificando...';
  if(role==='admin'){S.fn='admin';S.sc='admin';R();return;}
  const dup=await dbDup(role,mat);
  if(dup){S.pf={nome,mat};S.sc='blocked';R();return;}
  S.fn=role;S.ans={};S.pf={nome,mat,cargo,turno,base,tempo};S.sc='quiz';R();
}

function rBlocked(){return`
<p class="logo">SAMU 192 Sorocaba · CRU</p>
<div class="bb"><strong>Avaliação já realizada.</strong><br>A matrícula <strong>${S.pf.mat}</strong> já possui resposta registrada.<br><br>Cada servidor pode responder apenas uma vez. Se acredita que houve erro, entre em contato com a coordenação.</div>`;}

function rQuiz(){
  const fn=S.fn,fnD=DATA[fn],total=tQ(fn),done=Object.keys(S.ans).length,pct=Math.round(done/total*100);
  let h=`<p class="logo">SAMU 192 Sorocaba · CRU</p>
<div style="margin-bottom:1.25rem"><div style="font-size:15px;font-weight:600;margin-bottom:3px">Avaliação — ${fnD.label} (${fnD.fullLabel})</div>
<div style="font-size:12px;color:var(--text2)">${S.pf.nome} · Matrícula ${S.pf.mat} · ${S.pf.cargo}</div></div>
<div class="pw"><div class="pr"><span>Progresso</span><span id="pt">${done} / ${total} respondidas</span></div><div class="pb"><div class="pf" id="pf" style="width:${pct}%"></div></div></div>`;
  fnD.sections.forEach(sec=>{
    h+=`<div class="sec"><div class="st">${sec.title}</div>`;
    sec.questions.forEach((q,i)=>{
      h+=`<div class="qc"><div class="qt"><span class="qn">${i+1}</span><span class="qtx">${q.text}</span></div><div class="ops">`;
      q.options.forEach((o,oi)=>{
        const s=S.ans[q.id]===oi;
        h+=`<div class="or${s?' s':''}" id="ro-${q.id}-${oi}" onclick="pick('${q.id}',${oi})"><input class="ora" type="radio" name="${q.id}" id="${q.id}_${oi}" ${s?'checked':''}><label class="ol" for="${q.id}_${oi}">${String.fromCharCode(65+oi)}) ${o}</label></div>`;
      });
      h+=`</div></div>`;
    });
    h+=`</div>`;
  });
  h+=`<div class="act"><button class="btn bp" id="bs" ${done===total?'':'disabled'} onclick="sub()">Finalizar e enviar respostas</button><span class="ht" id="sh">${done<total?'Responda todas as questões para finalizar.':''}</span></div>`;
  return h;
}

function pick(qid,val){
  S.ans[qid]=val;
  DATA[S.fn].sections.forEach(s=>{s.questions.forEach(q=>{
    if(q.id===qid)q.options.forEach((_,oi)=>{
      const r=document.getElementById(`ro-${qid}-${oi}`);if(r)r.className='or'+(oi===val?' s':'');
      const i=document.getElementById(`${qid}_${oi}`);if(i)i.checked=(oi===val);
    });
  })});
  const total=tQ(S.fn),done=Object.keys(S.ans).length,pct=Math.round(done/total*100);
  const pf=document.getElementById('pf');if(pf)pf.style.width=pct+'%';
  const pt=document.getElementById('pt');if(pt)pt.textContent=`${done} / ${total} respondidas`;
  const bs=document.getElementById('bs'),sh=document.getElementById('sh');
  if(bs&&done===total){bs.removeAttribute('disabled');if(sh)sh.textContent='';}
}

async function sub(){
  const btn=document.getElementById('bs');if(btn)btn.disabled=true;
  S.sc='loading';R();
  const sc=score(S.fn,S.ans),pct=Math.round(sc.ok/sc.tot*100);
  await dbSave({fn:S.fn,profile:S.pf,pct,ok:sc.ok,tot:sc.tot,critFail:sc.cf.length,ts:new Date().toISOString()});
  S.sc='done';R();
}

function rDone(){return`
<p class="logo">SAMU 192 Sorocaba · CRU</p>
<div class="db"><strong>Avaliação concluída com sucesso.</strong><br>Obrigado, <strong>${S.pf.nome}</strong>. Suas respostas foram registradas.<br><br>O resultado será analisado pela coordenação antes do início do treinamento. Você receberá as orientações sobre os próximos passos diretamente pela chefia imediata.<br><br><span style="font-size:12px;opacity:.8">Você já pode fechar esta janela.</span></div>`;}

async function rAdminA(){
  document.getElementById('root').innerHTML=`<p class="logo">SAMU 192 Sorocaba · Painel DTM</p><div class="lb">Carregando dados...</div>`;
  const all=await dbLoad();
  document.getElementById('root').innerHTML=rAdmin(all);
}

function rAdmin(all){
  const tab=S.at,rows=all.filter(r=>r.fn===tab);
  const avg=rows.length?Math.round(rows.reduce((a,r)=>a+r.pct,0)/rows.length):0;
  const noc=rows.filter(r=>r.critFail===0).length,nod=rows.filter(r=>r.pct<60).length;
  let h=`<p class="logo">SAMU 192 Sorocaba · Painel DTM — Avaliação diagnóstica CRU</p>
<div class="tabs">${['tarm','ro','mr'].map(fn=>`<button class="tab${tab===fn?' a':''}" onclick="sat('${fn}')">${DATA[fn].label} (${all.filter(r=>r.fn===fn).length})</button>`).join('')}
<button class="tab" onclick="expCSV()">Exportar CSV</button>
<button class="tab bd" onclick="if(confirm('Apagar TODOS os registros? Esta ação não pode ser desfeita.'))clrAll()">Limpar dados</button></div>
<div class="sg">
<div class="sv"><div class="sl">Respondentes</div><div class="sn">${rows.length}</div></div>
<div class="sv"><div class="sl">Média geral</div><div class="sn">${avg}%</div></div>
<div class="sv"><div class="sl">Sem erro crítico</div><div class="sn">${noc}</div></div>
<div class="sv"><div class="sl">Risco operacional</div><div class="sn">${nod}</div></div>
</div>`;
  if(!rows.length){h+=`<div class="mt">Nenhuma resposta registrada para ${DATA[tab].label} ainda.</div>`;}
  else{
    h+=`<div class="tw"><table><tr><th>Nome</th><th>Matrícula</th><th>Cargo</th><th>Turno</th><th>Base</th><th>Tempo</th><th>Acertos</th><th>Erros críticos</th><th>Data / hora</th><th>Sinal</th></tr>`;
    rows.slice().sort((a,b)=>new Date(b.ts)-new Date(a.ts)).forEach(r=>{
      const s=sig(r.pct,r.critFail);
      h+=`<tr><td>${r.profile.nome}</td><td>${r.profile.mat}</td><td>${r.profile.cargo}</td><td>${r.profile.turno}</td><td>${r.profile.base}</td><td>${r.profile.tempo}</td><td>${r.ok}/${r.tot} (${r.pct}%)</td><td>${r.critFail}</td><td>${fdt(r.ts)}</td><td><span class="ch ${s.c}">${s.l}</span></td></tr>`;
    });
    h+=`</table></div>`;
  }
  h+=`<div class="sep"></div><p class="nt">Códigos · TARM: <strong>TARM2026</strong> | RO: <strong>RO2026</strong> | MR: <strong>MR2026</strong> | DTM: <strong>DTMGAZOTTO</strong></p>`;
  return h;
}

function sat(t){S.at=t;rAdminA();}
async function clrAll(){await dbClear();rAdminA();}
async function expCSV(){
  const all=await dbLoad();
  if(!all.length){alert('Nenhum dado para exportar.');return;}
  let csv='Nome,Matrícula,Cargo,Turno,Base,Tempo no serviço,Função avaliada,Acertos,Total,Percentual,Erros críticos,Data hora\n';
  all.forEach(r=>{const dt=fdt(r.ts);csv+=`"${r.profile.nome}","${r.profile.mat}","${r.profile.cargo}","${r.profile.turno}","${r.profile.base}","${r.profile.tempo}","${r.fn}",${r.ok},${r.tot},${r.pct}%,${r.critFail},"${dt}"\n`;});
  const blob=new Blob([csv],{type:'text/csv;charset=utf-8;'});
  const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='baseline_CRU_SAMU_Sorocaba.csv';a.click();URL.revokeObjectURL(url);
}

R();
